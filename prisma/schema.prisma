    generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


//--------------------------------------------------------------------------------


// ============================================
// SUPER ADMIN
// ============================================

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}

// ============================================
// INSTRUCTOR (كان اسمه Admin قبل كده)
// ============================================

model Instructor {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  instructorGroups InstructorGroup[]

  @@map("instructors")
}

// ============================================
// STUDENT
// ============================================

model Student {
  id        String   @id // كود الطالب اللي بيستخدمه كـ"باسورد" - مش auto-generated
  email     String   @unique
  name      String
  groupId   String
  levelSt   Int      @default(50) // بترجع 50 مع كل Level جديد، مفيش حد أدنى (ممكن تطلع سالبة)
  totalSt   Int      @default(0)  // تراكمي طول الـ Batch، مفيش حد أدنى (ممكن تطلع سالبة)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  group             Group              @relation(fields: [groupId], references: [id])
  submissions       Submission[]
  hintUnlocks       HintUnlock[]
  attendance        Attendance[]
  stTransactions    STTransaction[]
  storeInventory    StudentInventory[]

  @@map("students")
}

// ============================================
// BATCH
// ============================================

model Batch {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  groups Group[]

  @@map("batches")
}

// ============================================
// GROUP
// ============================================

model Group {
  id        String   @id @default(uuid())
  name      String
  batchId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  batch            Batch              @relation(fields: [batchId], references: [id])
  students         Student[]
  instructorGroups InstructorGroup[]
  levels           Level[]

  @@map("groups")
}

// ============================================
// INSTRUCTOR_GROUP (كان اسمه AdminGroup قبل كده)
// ============================================

model InstructorGroup {
  id           String   @id @default(uuid())
  instructorId String
  groupId      String
  createdAt    DateTime @default(now())

  // Relations
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([instructorId, groupId])
  @@map("instructor_groups")
}


//--------------------------------------------------------------------------------


// ============================================
// LEVEL
// ============================================
// كل Group ليه الـ Levels الخاصة بيه (مش جدول عام مشترك).
// في أي لحظة، Level واحد بس isActive = true لكل Group.
// لما الـ Instructor "ينقل" الـ Group لـ Level جديد:
//   1) الـ Level الحالي isActive -> false
//   2) Level جديد بيتعمل/يتفعّل بـ isActive = true و startDate = now()
//   3) level_st بتاع كل طلاب الـ Group يتصفّر (منطق ده هيبقى في Phase 4)

model Level {
  id          String    @id @default(uuid())
  groupId     String
  name        String
  description String?
  levelNumber Int
  startDate   DateTime  @default(now())
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  group          Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sessions       Session[]
  stTransactions STTransaction[]

  @@map("levels")
}

// ============================================
// SESSION
// ============================================
// موعد فعلي (تاريخ + وقت + مدة) تابع لـ Level معيّن.
// الـ status (upcoming/ongoing/completed) بيتحسب runtime من
// startTime و durationMinutes، مش عمود مخزّن.

model Session {
  id               String   @id @default(uuid())
  levelId          String
  title            String
  startTime        DateTime
  durationMinutes  Int
  recordingLink    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  level      Level        @relation(fields: [levelId], references: [id], onDelete: Cascade)
  tasks      Task[]
  attendance Attendance[]

  @@map("sessions")
}

// ============================================
// TASK TYPE ENUM
// ============================================
// INTERNAL: Task كاملة (Level 1) - ليها Submission + Hints
// EXTERNAL: Task خارجية (Level 2) - رابط خارجي بس + Hints

enum TaskType {
  INTERNAL
  EXTERNAL
}

// ============================================
// TASK
// ============================================
// كل Task تابعة لـ Session واحدة.
// deadline لازم يكون قبل بداية الـ Session اللي بعدها.
// isBonus بتفرّق الـ Task العادية عن الـ Bonus (بيأثر على الـ ST reward في Phase 4).

model Task {
  id          String   @id @default(uuid())
  sessionId   String
  title       String
  description String
  type        TaskType
  deadline    DateTime
  isBonus     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  hints       Hint[]
  submissions Submission[]

  @@map("tasks")
}

// ============================================
// HINT
// ============================================
// كل Task ليها بالظبط 3 Hints. مفيش ترتيب إجباري للفتح.
// cost بيتخصم مرة واحدة، وبعدها الـ Hint مفتوح للأبد لنفس الطالب
// (تتبّع "مين فتح إيه" هيبقى في HintUnlock - Phase 3).

model Hint {
  id        String   @id @default(uuid())
  taskId    String
  order     Int // 1, 2, or 3 - للعرض بس
  content   String
  cost      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  hintUnlocks HintUnlock[]

  @@unique([taskId, order])
  @@map("hints")
}


//--------------------------------------------------------------------------------


// ============================================
// SUBMISSION MODE ENUM
// ============================================
// FILE: رفع ملف واحد (أي نوع، حد أقصى 5MB) على Supabase Storage
// LINK: رابط خارجي (مثلاً GitHub, CodeSandbox, ...)
// TEXT: نص ملصوق مباشرة

enum SubmissionMode {
  FILE
  LINK
  TEXT
}

// ============================================
// SUBMISSION
// ============================================
// Row واحد بس لكل (studentId, taskId) - unique constraint.
// الـ resubmit = UPDATE على نفس الـ row (submittedAt بيتحدث تلقائيًا)،
// المحتوى القديم بيتمسح، مفيش history table.
//
// الـ resubmit بيتمنع لو:
//   1) الـ deadline بتاع الـ Task عدى، أو
//   2) isLocked = true (بيتفعّل لما الـ Instructor يقيّم الـ submission -
//      حتى لو ده حصل قبل الـ deadline، عشان التقييم ميبقاش على نسخة اتغيرت بعده)
//
// ملحوظة معمارية مهمة: رفع الـ Submission وحده مبيديش ST فورًا.
// الـ ST (submit +5 / not-submitted -10) بتتحسب بعد ما الـ deadline يعدي
// (Phase 4 scheduled check)، والـ rubric grading (+0 إلى +10) بيحصل
// في أي وقت بعد التسليم بفعل الـ Instructor - مش مرتبط بالـ deadline.

model Submission {
  id            String         @id @default(uuid())
  studentId     String
  taskId        String
  mode          SubmissionMode

  // محتوى التسليم - عمود واحد بس هيتملي حسب الـ mode
  fileUrl       String? // لو mode = FILE (مسار الملف في Supabase Storage)
  externalLink  String? // لو mode = LINK
  textContent   String? // لو mode = TEXT

  submittedAt   DateTime       @default(now()) @updatedAt
  isLocked      Boolean        @default(false) // بيتفعّل وقت التقييم، بيمنع أي resubmit بعد كده

  // Evaluation (merged في نفس الـ row - مش جدول منفصل)
  understandingScore  Int? // 0-2
  approachScore       Int? // 0-3
  correctnessScore    Int? // 0-3
  implementationScore Int? // 0-2
  instructorComment   String?
  gradedAt            DateTime?
  gradedBy            String? // instructorId اللي قيّم

  createdAt     DateTime       @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([studentId, taskId])
  @@map("submissions")
}

// ============================================
// HINT UNLOCK
// ============================================
// بيتبّع مين فتح إيه من الـ Hints. الفتح بيحصل مرة واحدة بس لكل
// (studentId, hintId) - unique constraint - وبعدها الـ Hint مفتوح للأبد.
// costPaid بيسجّل الكلفة وقت الفتح فعليًا (snapshot)، عشان لو الـ cost
// اتغيّر بعدين في الـ Hint نفسها، السجل التاريخي مايتأثرش.

model HintUnlock {
  id         String   @id @default(uuid())
  studentId  String
  hintId     String
  costPaid   Int
  unlockedAt DateTime @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  hint    Hint    @relation(fields: [hintId], references: [id], onDelete: Cascade)

  @@unique([studentId, hintId])
  @@map("hint_unlocks")
}

// ============================================
// ATTENDANCE STATUS ENUM
// ============================================

enum AttendanceStatus {
  PRESENT
  ABSENT
}

// ============================================
// ATTENDANCE
// ============================================
// تسجيل يدوي بالكامل من الـ Instructor أثناء/بعد الـ Session.
// مفيش حالة LATE - PRESENT أو ABSENT بس.
// (studentId, sessionId) unique - تسجيل واحد بس لكل طالب لكل Session.

model Attendance {
  id         String           @id @default(uuid())
  studentId  String
  sessionId  String
  status     AttendanceStatus
  recordedBy String // instructorId اللي سجّل الحضور
  recordedAt DateTime         @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId])
  @@map("attendance")
}


//--------------------------------------------------------------------------------


// ============================================
// ST TRANSACTION TYPE ENUM
// ============================================

enum STTransactionType {
  REWARD
  PENALTY
}

// ============================================
// ST REASON ENUM
// ============================================
// السبب الثابت اللي خلّى الحركة تحصل. كل الأسباب المتفق عليها في
// نظام الـ ST economy، ثابتة كـ enum عشان consistency و validation
// على مستوى الـ DB.

enum STReason {
  // Rewards
  ATTENDANCE
  SESSION_ENGAGEMENT
  SUBMIT_BEFORE_DEADLINE
  BONUS_TASK_SOLVED
  FIRST_SOLVER
  FINISH_ALL_TASKS
  RUBRIC_GRADING
  WEEKLY_MISSION

  // Penalties
  HINT_UNLOCK
  MISSED_SESSION
  TASK_NOT_SUBMITTED

  // Store
  STORE_PURCHASE

  // Manual
  MANUAL_ADJUSTMENT
}

// ============================================
// ST TRANSACTION
// ============================================
// سجل تدقيق (audit log) كامل لكل حركة ST تحصل لأي طالب، سواء كانت
// موجبة (REWARD) أو سالبة (PENALTY). amount دايمًا رقم موجب - الإشارة
// بتتحدد من type.
//
// levelId: الـ Level اللي الحركة حصلت فيه فعليًا وقتها - بيتسجّل عشان
// لو الطالب اتنقل لـ Level تاني بعدين، السجل التاريخي يفضل دقيق.
//
// relatedEntityId: عمود generic (من غير FK فعلي) بيخزن ID أي entity
// سبّب الحركة - مثلاً taskId لو SUBMIT_BEFORE_DEADLINE، hintId لو
// HINT_UNLOCK، sessionId لو ATTENDANCE، storeItemId لو STORE_PURCHASE.
//
// levelStBalance / totalStBalance: snapshot لرصيد الطالب مباشرة بعد
// تنفيذ هذه الحركة بالذات - عشان نقدر نعرض تاريخ الرصيد بالظبط في أي
// لحظة من غير ما نضطر نجمع كل الحركات من الأول كل مرة.

model STTransaction {
  id              String            @id @default(uuid())
  studentId       String
  levelId         String
  type            STTransactionType
  reason          STReason
  amount          Int // دايمًا موجب
  relatedEntityId String? // generic - بدون foreign key فعلي
  levelStBalance  Int // snapshot بعد الحركة
  totalStBalance  Int // snapshot بعد الحركة
  createdAt       DateTime          @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  level   Level   @relation(fields: [levelId], references: [id])

  @@map("st_transactions")
}

// ============================================
// STORE ITEM
// ============================================
// المتجر حاليًا Avatar items بس (ميزة الـ Editorial اتلغت بالكامل
// من العميل). isActive بيسمح للـ SuperAdmin يوقف منتج مؤقتًا من
// غير ما يمسحه (عشان الطلاب اللي امتلكوه يفضل ظاهر عندهم).

model StoreItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  cost        Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  purchases StudentInventory[]

  @@map("store_items")
}

// ============================================
// STUDENT INVENTORY
// ============================================
// إيه اللي الطالب امتلكه فعليًا من الـ Store. (studentId, storeItemId)
// unique - الطالب يقدر يمتلك نفس الـ item مرة واحدة بس، مفيش شراء متكرر.
// isEquipped بيحدد هل الطالب "لابس" الـ item ده دلوقتي في الـ Avatar بتاعه.

model StudentInventory {
  id          String   @id @default(uuid())
  studentId   String
  storeItemId String
  isEquipped  Boolean  @default(false)
  purchasedAt DateTime @default(now())

  // Relations
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  storeItem StoreItem @relation(fields: [storeItemId], references: [id])

  @@unique([studentId, storeItemId])
  @@map("student_inventory")
}
