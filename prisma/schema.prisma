    generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


//--------------------------------------------------------------------------------


// ============================================
// SUPER ADMIN
// ============================================

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}

// ============================================
// INSTRUCTOR (كان اسمه Admin قبل كده)
// ============================================

model Instructor {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  instructorGroups InstructorGroup[]

  @@map("instructors")
}

// ============================================
// STUDENT
// ============================================

model Student {
  id        String   @id // كود الطالب اللي بيستخدمه كـ"باسورد" - مش auto-generated
  email     String   @unique
  name      String
  groupId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  group Group @relation(fields: [groupId], references: [id])

  @@map("students")
}

// ============================================
// BATCH
// ============================================

model Batch {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  groups Group[]

  @@map("batches")
}

// ============================================
// GROUP
// ============================================

model Group {
  id        String   @id @default(uuid())
  name      String
  batchId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  batch            Batch              @relation(fields: [batchId], references: [id])
  students         Student[]
  instructorGroups InstructorGroup[]
  levels           Level[]

  @@map("groups")
}

// ============================================
// INSTRUCTOR_GROUP (كان اسمه AdminGroup قبل كده)
// ============================================

model InstructorGroup {
  id           String   @id @default(uuid())
  instructorId String
  groupId      String
  createdAt    DateTime @default(now())

  // Relations
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([instructorId, groupId])
  @@map("instructor_groups")
}


//--------------------------------------------------------------------------------


// ============================================
// LEVEL
// ============================================
// كل Group ليه الـ Levels الخاصة بيه (مش جدول عام مشترك).
// في أي لحظة، Level واحد بس isActive = true لكل Group.
// لما الـ Instructor "ينقل" الـ Group لـ Level جديد:
//   1) الـ Level الحالي isActive -> false
//   2) Level جديد بيتعمل/يتفعّل بـ isActive = true و startDate = now()
//   3) level_st بتاع كل طلاب الـ Group يتصفّر (منطق ده هيبقى في Phase 4)

model Level {
  id          String    @id @default(uuid())
  groupId     String
  name        String
  description String?
  levelNumber Int
  startDate   DateTime  @default(now())
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@map("levels")
}

// ============================================
// SESSION
// ============================================
// موعد فعلي (تاريخ + وقت + مدة) تابع لـ Level معيّن.
// الـ status (upcoming/ongoing/completed) بيتحسب runtime من
// startTime و durationMinutes، مش عمود مخزّن.

model Session {
  id               String   @id @default(uuid())
  levelId          String
  title            String
  startTime        DateTime
  durationMinutes  Int
  recordingLink    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  level Level  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@map("sessions")
}

// ============================================
// TASK TYPE ENUM
// ============================================
// INTERNAL: Task كاملة (Level 1) - ليها Submission + Hints
// EXTERNAL: Task خارجية (Level 2) - رابط خارجي بس + Hints

enum TaskType {
  INTERNAL
  EXTERNAL
}

// ============================================
// TASK
// ============================================
// كل Task تابعة لـ Session واحدة.
// deadline لازم يكون قبل بداية الـ Session اللي بعدها.
// isBonus بتفرّق الـ Task العادية عن الـ Bonus (بيأثر على الـ ST reward في Phase 4).

model Task {
  id          String   @id @default(uuid())
  sessionId   String
  title       String
  description String
  type        TaskType
  deadline    DateTime
  isBonus     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  hints   Hint[]

  @@map("tasks")
}

// ============================================
// HINT
// ============================================
// كل Task ليها بالظبط 3 Hints. مفيش ترتيب إجباري للفتح.
// cost بيتخصم مرة واحدة، وبعدها الـ Hint مفتوح للأبد لنفس الطالب
// (تتبّع "مين فتح إيه" هيبقى في HintUnlock - Phase 3).

model Hint {
  id        String   @id @default(uuid())
  taskId    String
  order     Int // 1, 2, or 3 - للعرض بس
  content   String
  cost      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, order])
  @@map("hints")
}
